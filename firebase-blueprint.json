{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information and role",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Document": {
      "title": "SPJ Document",
      "description": "Information about the uploaded SPJ document",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "fileUrl": { "type": "string" },
        "uploadedBy": { "type": "string" },
        "uploaderName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "verified", "rejected"] },
        "feedback": { "type": "string" },
        "verifiedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "fileUrl", "uploadedBy", "status", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Notifications for users",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "read", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User collection"
    },
    "/documents/{docId}": {
      "schema": "Document",
      "description": "SPJ documents collection"
    },
    "/notifications/{notifId}": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
